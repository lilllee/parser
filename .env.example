# Copy to .env for local development. Do not commit real internal/private URLs.
VLLM_URL=http://localhost:8000/v1/chat/completions
# ⚠ 서버가 /v1/models 로 노출하는 실제 model id 와 정확히 일치해야 함(틀리면 404). 현재 서버 A = qwen/qwen3.6-27b.
VLLM_MODEL=qwen/qwen3.6-27b
VLLM_DISABLED=0

# force_ocr 서버 기본값. 1 = PDF 를 kordoc 우회하고 전체페이지 vision OCR(+숫자검증·차트 enrich)로
# 처리(정확도 우선, 느림). HWP/HWPX/DOCX 는 자동 제외돼 kordoc 전처리 유지, 이미지는 원래 vision.
# 컨텍스트 초과 페이지는 1024 단일뷰→그리드타일(DeepSeek) 폴백. 요청에 force_ocr 명시하면 그게 우선.
FORCE_OCR=1

# ── 토큰 캡 / 동시성 (성능·품질 튜닝) ────────────────────────────────────
# 출력 토큰 캡은 '상한'일 뿐 — 안 채우면 비용 0(실측 평균 출력 ~640tok). enrich 설명이 짧게
# 끊기면 해당 캡만 올린다. 단 decode 가 느린 큰 모델이라 '실제로 길게 쓰면' 그 호출만 느려진다.
# VLLM_OCR_MAX_TOKENS=8192           # 페이지 OCR 출력(잘리면 AI_MAX_TOKENS_CAP 까지 자동 확장)
# VLLM_PAGE_VISUAL_MAX_TOKENS=1280   # 차트/그림 설명(코드 기본 1280)
# VLLM_IMAGE_MAX_TOKENS=1024         # 이미지 분석(코드 기본 1024)
# VLLM_TABLE_MAX_TOKENS=1024         # 표 요약(코드 기본 1024 · VLLM_TABLE_ANALYSIS=1 일 때만)
# AI_MAX_TOKENS_CAP=16384            # 잘림 재시도 확장 상한. 잘림 로그 실제로 보일 때만 ↑(입력+출력 ≤ 32768)
# 동시성 — 문서 전체 wall-clock 의 진짜 레버. ⚠ 느린 단일 122B 서버(Intel/Qwen3.5-122B-A10B,
# 실측 ~13.6 tok/s)에선 '낮추는' 게 처리량을 올린다: 많이 던지면 서로 decode 예산을 다투다 다 같이
# 느려져 한꺼번에 timeout→abort(여러 페이지 동시 "aborted"). 3~4 면 각 요청이 timeout 전에 끝나 더 빠름.
# anchor/numeric-repair 로 페이지당 비용이 커져 높은 동시성은 쉽게 포화된다. 서버 --max-num-seqs(/metrics) 확인.
# VLLM_CONCURRENCY=3                 # enrich 동시 호출(코드 기본 3)
# VLLM_OCR_CONCURRENCY=3             # 페이지 OCR 동시 호출(코드 기본 3 · "aborted" 뜨면 더 낮추기)
# VLLM_OCR_TIMEOUT_MS=600000         # OCR 1건 타임아웃(코드 기본 10분 · 240000=4분은 과부하 시 더 잘 터짐)
# VLLM_ENRICH_TIMEOUT_MS=240000      # enrich(차트/표 해설) 1건 타임아웃(코드 기본 240s · 공용 60s 는 122B vision 에 짧아 fail)
# VLLM_OCR_RENDER_SCALE=2            # 페이지 렌더 배율(코드 기본 3). 2 로 낮추면 입력 토큰↓ → 호출당↑속도
# VLLM_OCR_TABLE_RETRY=2            # 깨진 표 페이지 순차 재호출 폭주 억제(코드 기본 2)

# MinerU 문서 파싱 서버(provider=mineru). base URL 만 — /file_parse·/health 자동 부착.
# 파일을 통째 업로드해 MinerU 가 직접 md 로 변환(kordoc/reflow/enrich 우회). PDF·이미지·DOCX 위주.
# 백엔드 2개로 OCR 특성 분기: hybrid-engine(VLM, 복잡 표/PDF)=8000, pipeline(PaddleOCR, 이미지/한글 정확)=8002.
# backend=auto(기본): 이미지→pipeline, 그 외→hybrid-engine 자동 라우팅.
MINERU_URL=http://192.168.0.50:8000
MINERU_PIPELINE_URL=http://192.168.0.50:8002
# MINERU_BACKEND=auto          # auto|hybrid-engine|pipeline
MINERU_LANG=korean
MINERU_PARSE_METHOD=auto# auto|txt|ocr
MINERU_FORMULA=1 # 0 이면 수식 인식 끔
MINERU_IMAGE_ANALYSIS=1# 1 이면 그림/차트 설명 시도
MINERU_POSTPROCESS=0# 1 이면 우리 postprocess 적용(기본 0 = 원본 그대로)

# OCR(페이지 전사) 샘플링 — 모델별 튜닝용. 기본값은 순수 greedy(temp 0, rep_penalty off)로
# 현재 모델(Intel/Qwen3.5-122B-A10B)에 맞춤(전사·숫자 충실도 최고, 결정적). 구모델(Qwen3 계열)은 temp~0 에서 빈 영역
# <br>/개행 무한반복(degeneration)이 있어, 그 모델로 회귀 시 아래 둘을 주석 해제해 되돌린다.
# VLLM_OCR_TEMPERATURE=0          # 구모델은 0.1
# VLLM_OCR_REPETITION_PENALTY=1.0 # 구모델은 1.1 (degeneration 차단)
# VLLM_OCR_FREQUENCY_PENALTY=0
# VLLM_OCR_PRESENCE_PENALTY=0
# VLLM_OCR_TOP_P=1.0

# ── reflow 경로 OCR 품질(모두 기본 on, =0 이면 legacy byte-identical 로 복귀) ──
# P0 anchor: kordoc 텍스트레이어를 vision OCR 보조 입력으로 주입(숫자·철자 오독↓). 펼침면·한글
#   무공백 뭉침 페이지는 자동 제외. force_ocr 경로는 적용 안 함(사용자가 텍스트레이어 불신 모드).
# VLLM_OCR_ANCHOR=1
# VLLM_OCR_ANCHOR_MAX_CHARS=2000      # anchor user 블록 cap(초과 시 표/숫자/헤더 우선 압축)
# P0.5 numeric repair: 전사 후 kordoc 숫자와 대조해 누락/오독이 임계 이상이면 보정 재호출(accept/rollback).
#   decode ~13.6tok/s 라 비용 큼 → 보수적(임계 2, 재시도 1회). missing 만 줄고 환각(extra) 안 늘 때만 채택.
# VLLM_OCR_NUMERIC_REPAIR=1
# VLLM_OCR_NUMERIC_REPAIR_MAX=1
# VLLM_OCR_NUMERIC_REPAIR_MIN_MISMATCH=2
# P1 페이지 인덱스: OCR 프롬프트에 '페이지 N / 총 M' 주입(마지막/이어짐 판단 단서).
# VLLM_OCR_PAGE_INFO=1
# P1.5 차트 enrich: 텍스트 PDF(kordoc) 경로의 차트/그림 페이지도 렌더해 해설 enrich(스캔/force_ocr 는 무관).
# VLLM_PAGE_VISUAL_REFLOW=1

# ── OCR 전용 서버 B (PaddleOCR-VL doc-parser @ :8500) ────────────────────────
# reflow 페이지 OCR 엔진: qwen(기본, 서버 A vision) / paddle(서버 B /api/v1/parse, HTML표 복원·빠름).
# paddle 은 PADDLE_PARSE_URL 설정 + OCR_BACKEND=paddle 일 때만 동작(미설정/qwen 이면 기존과 동일).
# Paddle 표는 kordoc 숫자 게이트(comparePageNumbers) 통과분만 채택, 실패 시 kordoc 폴백.
# OCR_BACKEND=paddle
# PADDLE_PARSE_URL=http://192.168.0.250:8500   # doc-parser API base(/api/v1/parse·/api/health 자동 부착)
# PADDLE_PARSE_TIMEOUT_MS=300000               # /parse 1건 타임아웃
# PADDLE_CLEAN_HTML=1                           # <table> border/inline style 제거·셀\n→<br>(서버 R1)
# PADDLE_DROP_IMAGES=1                          # 빈 <img> 참조 제거(차트는 Qwen enrich 담당, 서버 R2)
# PADDLE_PARSE_DPI=                             # 빈 값=서버 기본 200. 어려운 페이지만 ↑(정밀↑/속도↓)
# provider=paddle_parse 로 호출하면 파일 통째 /parse(문서 파서, kordoc 우회) — 벤치/단독용.

# AWS Bedrock Converse. Credentials are resolved from AWS_PROFILE/default chain,
# or explicit AWS_* / BEDROCK_* env vars if configured on the server.
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_PROFILE=default
